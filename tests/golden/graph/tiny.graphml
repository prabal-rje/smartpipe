<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d0" for="node" attr.name="label" attr.type="string"/>
  <key id="d1" for="node" attr.name="count" attr.type="int"/>
  <key id="d2" for="edge" attr.name="relation" attr.type="string"/>
  <key id="d3" for="edge" attr.name="weight" attr.type="int"/>
  <key id="d4" for="edge" attr.name="sources" attr.type="string"/>
  <graph id="G" edgedefault="undirected">
    <node id="Acme Corp">
      <data key="d0">company</data>
      <data key="d1">7</data>
    </node>
    <node id="Maria Schneider">
      <data key="d0">person</data>
      <data key="d1">5</data>
    </node>
    <node id="Zurich">
      <data key="d0">location</data>
      <data key="d1">2</data>
    </node>
    <edge source="Acme Corp" target="Maria Schneider">
      <data key="d2">co-occurs</data>
      <data key="d3">4</data>
      <data key="d4">notes.txt:12 · report.pdf p.3</data>
    </edge>
    <edge source="Acme Corp" target="Zurich">
      <data key="d2">co-occurs</data>
      <data key="d3">2</data>
      <data key="d4">call.wav §00:10-00:20 · +1 more</data>
    </edge>
    <edge source="Maria Schneider" target="Zurich">
      <data key="d2">co-occurs</data>
      <data key="d3">1</data>
      <data key="d4">notes.txt:30</data>
    </edge>
  </graph>
</graphml>
