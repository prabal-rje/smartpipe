graph smartpipe {
  layout=neato;
  overlap=false;
  splines=true;
  node [shape=ellipse, style=filled, fillcolor="#e8f7fb", color="#22809a", fontname="Helvetica"];
  edge [color="#8899aa"];
  "Acme Corp" [label="Acme Corp (7)", tooltip="company · 7 mentions"];
  "Maria Schneider" [label="Maria Schneider (5)", tooltip="person · 5 mentions"];
  "Zurich" [label="Zurich (2)", tooltip="location · 2 mentions"];
  "Acme Corp" -- "Maria Schneider" [penwidth=5, tooltip="co-occurs ×4 — notes.txt:12 · report.pdf p.3"];
  "Acme Corp" -- "Zurich" [penwidth=2, tooltip="co-occurs ×2 — call.wav §00:10-00:20 · +1 more"];
  "Maria Schneider" -- "Zurich" [penwidth=1, tooltip="co-occurs ×1 — notes.txt:30"];
}
